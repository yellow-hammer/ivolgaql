{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ИволгаQL: сборка",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "ИволгаQL: сервер",
      "type": "shell",
      "command": "cargo run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "ИволгаQL: тесты",
      "type": "shell",
      "command": "cargo test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "ИволгаQL: release",
      "type": "shell",
      "command": "cargo build --release",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$rustc"
    }
  ]
}
